{
  "manifest_version": 3,
  "name": "JobMatch Capture",
  "version": "0.1.0",
  "description": "Capture visible jobs from the current page and send them to JobMatch.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "JobMatch Capture",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
